generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
  REJECTED
}

enum PolicyTier {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
  CUSTOM
}

enum AgentStatus {
  ACTIVE
  SUSPENDED
  REVOKED
}

model AgentWallet {
  id            String        @id @default(cuid())
  agentId       String        @unique
  ownerId       String?
  address       String
  cdpWalletId   String?
  balanceUsdc   Float         @default(0)
  status        AgentStatus   @default(ACTIVE)
  metadata          Json?
  autoTopUpEnabled  Boolean   @default(false)
  topUpThreshold    Float?
  topUpAmount       Float?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sentTransactions     Transaction[] @relation("SentTransactions")
  receivedTransactions Transaction[] @relation("ReceivedTransactions")
  policies             SpendingPolicy[]
  credentials          AgentCredential[]

  @@map("agent_wallets")
}

model SpendingPolicy {
  id                  String      @id @default(cuid())
  agentId             String
  tier                PolicyTier  @default(CUSTOM)
  maxPerTransaction   Float
  dailyLimit          Float
  monthlyLimit        Float?
  allowedRecipients   String[]
  blockedMerchants    String[]
  allowedCategories   String[]
  requireApproval     Boolean     @default(false)
  isActive            Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  agent AgentWallet @relation(fields: [agentId], references: [agentId])

  @@map("spending_policies")
}

model Transaction {
  id              String            @id @default(cuid())
  fromAgentId     String
  toAddress       String
  toAgentId       String?
  amountUsdc      Float
  status          TransactionStatus @default(PENDING)
  txHash          String?
  category        String?
  memo            String?
  isP2P           Boolean           @default(false)
  policyChecks    Json?
  failureReason   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  fromAgent   AgentWallet  @relation("SentTransactions", fields: [fromAgentId], references: [agentId])
  toAgent     AgentWallet? @relation("ReceivedTransactions", fields: [toAgentId], references: [agentId])

  @@map("transactions")
}

model AgentCredential {
  id          String      @id @default(cuid())
  agentId     String
  label       String
  publicKey   String
  did         String?
  jwt         String?
  isRevoked   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  agent AgentWallet @relation(fields: [agentId], references: [agentId])

  @@map("agent_credentials")
}

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  keyHash     String   @unique
  prefix      String
  scopes      String[]
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())

  @@map("api_keys")
}

model Treasury {
  id              String  @id @default("default")
  balanceUsdc     Float   @default(0)
  totalFunded     Float   @default(0)
  totalDisbursed  Float   @default(0)

  @@map("treasury")
}

model PaywallEndpoint {
  id          String   @id @default(cuid())
  path        String   @unique
  priceUsdc   Float
  description String?
  isActive    Boolean  @default(true)
  totalPaid   Float    @default(0)
  hitCount    Int      @default(0)
  createdAt   DateTime @default(now())

  @@map("paywall_endpoints")
}

model Webhook {
  id          String   @id @default(cuid())
  url         String
  secret      String
  events      String[]
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@map("webhooks")
}

model MppEndpoint {
  id          String   @id @default(cuid())
  path        String   @unique
  priceUsdc   Float
  description String?
  intent      String   @default("charge")
  isActive    Boolean  @default(true)
  totalPaid   Float    @default(0)
  hitCount    Int      @default(0)
  createdAt   DateTime @default(now())

  payments MppPayment[]

  @@map("mpp_endpoints")
}

model MppPayment {
  id            String   @id @default(cuid())
  endpointId    String
  agentId       String
  amountUsdc    Float
  challengeId   String
  transactionId String?
  receipt       String?
  createdAt     DateTime @default(now())

  endpoint MppEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@map("mpp_payments")
}

enum ServiceType {
  DATA_FEED
  AI_MODEL
  API_GATEWAY
  COMPUTE
  STORAGE
  AGENT_SKILL
  COMMUNICATION

  @@map("service_type")
}

enum PaymentProtocol {
  X402
  MPP
  P2P

  @@map("payment_protocol")
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  DEPRECATED

  @@map("listing_status")
}

model MarketplaceListing {
  id              String          @id @default(cuid())
  slug            String          @unique
  name            String
  description     String
  shortDesc       String
  logoUrl         String?
  category        ServiceType
  tags            String[]
  providerAgentId String?
  providerName    String
  providerUrl     String?
  priceUsdc       Float
  pricingModel    String          @default("per-call")
  protocol        PaymentProtocol
  endpointPath    String?
  externalUrl     String?
  capabilities    Json            @default("{}")
  slaUptime       Float?
  avgLatencyMs    Int?
  totalRevenue    Float           @default(0)
  totalPurchases  Int             @default(0)
  avgRating       Float?
  reviewCount     Int             @default(0)
  status          ListingStatus   @default(DRAFT)
  isVerified      Boolean         @default(false)
  ownerId         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  reviews         ServiceReview[]
  purchases       ServicePurchase[]

  @@index([category])
  @@index([status])
  @@index([protocol])
  @@index([priceUsdc])
  @@map("marketplace_listings")
}

model ServiceReview {
  id              String   @id @default(cuid())
  listingId       String
  reviewerAgentId String
  rating          Int
  comment         String?
  createdAt       DateTime @default(now())

  listing         MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, reviewerAgentId])
  @@map("service_reviews")
}

model ServicePurchase {
  id              String          @id @default(cuid())
  listingId       String
  buyerAgentId    String
  transactionId   String?
  amountUsdc      Float
  protocol        PaymentProtocol
  accessToken     String?
  accessExpiresAt DateTime?
  createdAt       DateTime        @default(now())

  listing         MarketplaceListing @relation(fields: [listingId], references: [id])

  @@index([buyerAgentId])
  @@index([listingId])
  @@map("service_purchases")
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  webhookId   String
  event       String
  payload     Json
  statusCode  Int?
  success     Boolean  @default(false)
  error       String?
  createdAt   DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@map("webhook_deliveries")
}
